# Copy this file to .env and fill in the secrets. .env is gitignored.

# --- LLM (Groq) --- get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2

# --- Embeddings (local, free, no key) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Telegram --- create a bot via @BotFather, paste the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_MODE=polling            # polling (dev) | webhook (prod)
WEBHOOK_URL=                     # set only in prod, e.g. https://<app>.run.app/telegram/webhook

# --- Data stores (defaults match docker-compose.yml) ---
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql+psycopg://retail:retail@localhost:5432/retail
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=products

# --- API ---
API_URL=http://localhost:8000

# --- RAG tuning ---
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=4

# --- Memory ---
SESSION_TTL_SECONDS=86400        # auto-expire idle conversations (24h)
